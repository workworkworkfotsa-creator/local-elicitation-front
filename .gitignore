# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments (generated by `uv sync`; uv.lock is the source of truth, keep it)
.venv/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Model weights — large, runtime artifacts, never source
*.gguf

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local-only input data — NEVER commit company/business files to this public repo.
# Keep example files (e.g. a reconciliation .xlsx) here locally for Tier B tests.
input/*
!input/README.md
